[Unit]
Description=Margatroid Session Manager
After=network.target

[Service]
Type=simple
Environment=PATH=%h/.cargo/bin:%h/.local/bin:%h/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/bin/margatroid-boot
ExecStop=/usr/bin/tmux kill-session -t margatroid
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
