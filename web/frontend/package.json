{
  "name": "margatroid-web-frontend",
  "private": true,
  "type": "module",
  "source": "src/index.html",
  "scripts": {
    "dev": "parcel serve src/index.html",
    "build": "parcel build src/index.html --dist-dir ../static/dist --public-url ./ && node -e \"const c=require('crypto'),f=require('fs');process.stdout.write(c.createHash('sha256').update(f.readFileSync('../static/dist/index.html')).digest('hex').slice(0,12))\" > ../static/dist/.version",
    "test": "playwright test",
    "lint": "biome check src/"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@biomejs/biome": "^1",
    "parcel": "^2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ghostty-web": "^0.4.0"
  }
}
